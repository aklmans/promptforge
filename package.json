{
	"name": "promptforge",
	"version": "0.1.0",
	"description": "AI-powered prompt enhancement CLI tool",
	"license": "MIT",
	"type": "module",
	"files": ["dist", "README.md", "CHANGELOG.md", "docs/README.md", "docs/guides"],
	"bin": {
		"promptforge": "./dist/cli.js"
	},
	"scripts": {
		"dev": "tsup src/cli.tsx --watch --onSuccess 'node dist/cli.js'",
		"build": "tsup src/cli.tsx",
		"typecheck": "tsc --noEmit",
		"typecheck:test": "tsc --noEmit -p tsconfig.test.json",
		"lint": "biome check src tests docs README.md package.json tsconfig.json tsconfig.test.json tsup.config.ts biome.json",
		"lint:fix": "biome check --write src tests docs README.md package.json tsconfig.json tsconfig.test.json tsup.config.ts biome.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"release:check": "npm run lint && npm run typecheck && npm run typecheck:test && npm test && npm run build",
		"pack:dry": "npm pack --dry-run --cache ./.npm-cache",
		"prepublishOnly": "npm run release:check"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"ink": "^4.4.1",
		"react": "^18.3.1",
		"openai": "^4.52.0",
		"cosmiconfig": "^9.0.0",
		"zod": "^3.22.4",
		"clipboardy": "^4.0.0",
		"fs-extra": "^11.2.0",
		"diff": "^5.1.0",
		"fuse.js": "^7.0.0",
		"pino": "^8.17.2",
		"ink-text-input": "^5.0.0",
		"ink-select-input": "^5.0.0",
		"ink-spinner": "^5.0.0",
		"ink-gradient": "^3.0.0"
	},
	"devDependencies": {
		"typescript": "^5.3.3",
		"@types/react": "^18.2.45",
		"@types/fs-extra": "^11.0.4",
		"@types/diff": "^5.1.2",
		"@types/node": "^20.10.6",
		"tsup": "^8.0.2",
		"vitest": "^1.1.0",
		"@biomejs/biome": "^1.5.3"
	}
}
